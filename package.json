{
  "name": "workflow-agent-hub",
  "version": "0.5.15",
  "description": "Workflow Agent Hub — self-hosted multi-agent orchestration workspace for chat, workflows, applications, skills, and runtime operations",
  "repository": {
    "type": "git",
    "url": "https://github.com/iizhan/workflow-agent-hub.git"
  },
  "homepage": "https://github.com/iizhan/workflow-agent-hub",
  "license": "MIT",
  "engines": {
    "node": ">=23.0.0"
  },
  "keywords": [
    "workflow-agent-hub",
    "workflow-orchestration",
    "multi-agent",
    "agent",
    "ai",
    "ai-agent",
    "ai-chat",
    "ai-dashboard",
    "chatgpt",
    "claude",
    "openai",
    "gemini",
    "deepseek",
    "llm",
    "multi-model",
    "chat-ui",
    "dashboard",
    "self-hosted",
    "telegram",
    "discord",
    "slack",
    "whatsapp",
    "matrix",
    "feishu",
    "weixin",
    "multi-platform",
    "vue3",
    "typescript"
  ],
  "bin": {
    "hermes-web-ui": "./bin/hermes-web-ui.mjs"
  },
  "scripts": {
    "start": "vite --host --port 8648",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:isolated": "concurrently \"npm run dev:server:isolated\" \"npm run dev:client\"",
    "dev:client": "vite --host",
    "dev:server": "nodemon --signal SIGTERM --watch packages/server/src -e ts,tsx --exec TS_NODE_PROJECT=packages/server/tsconfig.json node -r ts-node/register packages/server/src/index.ts",
    "dev:server:isolated": "HERMES_WEBUI_HOME=.runtime/.hermes-web-ui nodemon --signal SIGTERM --watch packages/server/src -e ts,tsx --exec TS_NODE_PROJECT=packages/server/tsconfig.json node -r ts-node/register packages/server/src/index.ts",
    "build": "vue-tsc -b && vite build && tsc --noEmit -p packages/server/tsconfig.json && node scripts/build-server.mjs",
    "prepare": "[ -d dist ] || npm run build",
    "preview": "NODE_ENV=production vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "dev:website": "vite --config vite.config.website.ts",
    "build:website": "vite build --config vite.config.website.ts",
    "preview:website": "vite preview --config vite.config.website.ts",
    "openapi:generate": "node scripts/generate-openapi.mjs",
    "spec:new": "bash .specify/scripts/bash/create-new-feature.sh",
    "spec:plan": "bash .specify/scripts/bash/setup-plan.sh",
    "spec:tasks": "bash .specify/scripts/bash/setup-tasks.sh",
    "spec:checklist": "bash .specify/scripts/bash/setup-checklist.sh",
    "spec:doctor": "bash -n .specify/scripts/bash/*.sh",
    "claude": "claude --dangerously-skip-permissions"
  },
  "files": [
    "bin/",
    "dist/"
  ],
  "dependencies": {
    "eventsource": "^4.1.0",
    "js-tiktoken": "^1.0.21",
    "node-edge-tts": "^1.2.10",
    "node-pty": "^1.1.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@koa/bodyparser": "^5.0.0",
    "@koa/cors": "^5.0.0",
    "@koa/router": "^15.4.0",
    "@logicflow/core": "^2.2.3",
    "@logicflow/extension": "^2.2.3",
    "@multiavatar/multiavatar": "^1.0.7",
    "@pinia/testing": "^1.0.3",
    "@types/eventsource": "^1.1.15",
    "@types/js-yaml": "^4.0.9",
    "@types/koa": "^2.15.0",
    "@types/koa__cors": "^5.0.0",
    "@types/koa__router": "^12.0.5",
    "@types/koa-send": "^4.1.6",
    "@types/koa-static": "^4.0.4",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^24.12.2",
    "@types/qrcode": "^1.5.6",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "axios": "^1.9.0",
    "concurrently": "^9.2.1",
    "esbuild": "^0.27.0",
    "highlight.js": "^11.11.1",
    "js-yaml": "^4.1.1",
    "jsdom": "^27.0.1",
    "koa": "^2.15.3",
    "koa-send": "^5.0.1",
    "koa-static": "^5.0.0",
    "markdown-it": "^14.1.1",
    "mermaid": "^11.14.0",
    "monaco-editor": "^0.55.1",
    "naive-ui": "^2.44.1",
    "nodemon": "^3.1.14",
    "pinia": "^3.0.4",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "qrcode": "^1.5.4",
    "sass": "^1.99.0",
    "ts-node": "^10.9.2",
    "tsoa": "^7.0.0-alpha.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.4",
    "vitest": "^3.2.4",
    "vue": "^3.5.32",
    "vue-i18n": "^11.3.2",
    "vue-router": "^4.6.4",
    "vue-tsc": "^3.2.6",
    "ws": "^8.20.0"
  },
  "packageManager": "pnpm@10.28.0+sha1.99bafbd81cd8141d21254ec30f60efd7d5028f14"
}
